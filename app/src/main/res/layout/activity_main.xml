<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/piano_layout2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageButton
        android:id="@+id/c3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/white_key"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/d3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/white_key"
        app:layout_constraintStart_toEndOf="@+id/c3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/e3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/white_key"
        app:layout_constraintStart_toEndOf="@+id/d3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/f3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/white_key"
        app:layout_constraintStart_toEndOf="@+id/e3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/g3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/white_key"
        app:layout_constraintStart_toEndOf="@+id/f3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/a3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/white_key"
        app:layout_constraintStart_toEndOf="@+id/g3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/b3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/white_key"
        app:layout_constraintStart_toEndOf="@+id/a3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/c4"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/white_key"
        app:layout_constraintStart_toEndOf="@+id/b3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/cb3"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="200dp"
        android:background="@drawable/black_key"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/d3"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/c3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/db3"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="200dp"
        android:background="@drawable/black_key"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/e3"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/d3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/fb3"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="200dp"
        android:background="@drawable/black_key"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/g3"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/f3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/gb3"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="200dp"
        android:background="@drawable/black_key"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/a3"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/g3"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/ab3"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_marginBottom="200dp"
        android:background="@drawable/black_key"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/b3"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/a3"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>